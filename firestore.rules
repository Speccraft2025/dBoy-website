rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /beats/{beatId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /albums/{albumId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
